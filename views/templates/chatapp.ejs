<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Chatly • Simple Chat</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css"
    />
    <style>
      @import url("https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&display=swap");
      body {
        font-family: "Inter", sans-serif;
      }

      .chat-container {
        height: 100vh;
        display: flex;
        flex-direction: column;
      }

      .message-bubble {
        max-width: 75%;
        padding: 12px 16px;
        border-radius: 18px;
        position: relative;
      }

      .received {
        background-color: #f1f1f1;
        align-self: flex-start;
        border-bottom-left-radius: 4px;
      }

      .sent {
        background-color: #25d366;
        color: white;
        align-self: flex-end;
        border-bottom-right-radius: 4px;
      }

      .chat-input {
        background: white;
        border-top: 1px solid #e5e5e5;
      }
    </style>
  </head>
  <body class="bg-gray-100">
    <div
      class="chat-container max-w-md mx-auto bg-white shadow-2xl overflow-hidden h-screen flex flex-col"
    >
      <!-- HEADER -->
      <div class="bg-[#075E54] text-white p-4 flex items-center gap-3">
        <button onclick="showContacts()" class="text-2xl">
          <i class="fas fa-arrow-left"></i>
        </button>
        <div class="flex-1 flex items-center gap-3">
          <div
            id="chat-avatar"
            class="w-10 h-10 bg-white rounded-full flex items-center justify-center text-2xl"
          >
            👤
          </div>
          <div>
            <div id="chat-name" class="font-semibold">Select a contact</div>
            <div id="chat-status" class="text-xs text-green-200">online</div>
          </div>
        </div>
        <div class="flex gap-4 text-xl">
          <i class="fas fa-video"></i>
          <i class="fas fa-phone"></i>
          <i class="fas fa-ellipsis-v"></i>
        </div>
      </div>

      <!-- CHAT AREA -->
      <div
        id="chat-area"
        class="flex-1 p-4 overflow-y-auto bg-[#E5DDD5] flex flex-col gap-3"
      >
        <!-- Messages will be added here by JavaScript -->
      </div>

      <!-- INPUT AREA -->
      <div class="chat-input p-3 flex items-center gap-2 border-t">
        <button class="text-gray-500 px-3">
          <i class="fas fa-smile text-2xl"></i>
        </button>
        <input
          id="message-input"
          type="text"
          placeholder="Type a message..."
          class="flex-1 bg-gray-100 rounded-full px-5 py-3 focus:outline-none focus:ring-2 focus:ring-green-500"
          onkeypress="if (event.key === 'Enter') sendMessage();"
        />
        <button
          onclick="sendMessage()"
          class="bg-[#25D366] text-white w-10 h-10 rounded-full flex items-center justify-center"
        >
          <i class="fas fa-paper-plane"></i>
        </button>
      </div>
    </div>

    <!-- CONTACTS SIDEBAR (shown when clicking back) -->
    <div
      id="contacts-screen"
      class="hidden fixed inset-0 bg-white z-50 flex flex-col"
    >
      <div class="bg-[#075E54] text-white p-4 flex items-center gap-3">
        <button onclick="hideContacts()" class="text-2xl">
          <i class="fas fa-arrow-left"></i>
        </button>
        <h1 class="text-xl font-semibold">Chats</h1>
      </div>

      <div class="flex-1 overflow-y-auto" id="contacts-list">
        <!-- Contacts populated by JS -->
      </div>
    </div>

    <script>
      // Default contacts (like WhatsApp)
      let contacts = [
        {
          id: 1,
          name: "Sarah Chen",
          avatar: "👩🏻",
          lastMessage: "See you tomorrow!",
          time: "10:32",
          online: true,
        },
        {
          id: 2,
          name: "Mike Okoro",
          avatar: "🧔🏾",
          lastMessage: "Thanks for the help!",
          time: "09:15",
          online: false,
        },
        {
          id: 3,
          name: "Aisha Khan",
          avatar: "👩🏽",
          lastMessage: "Did you see the new update?",
          time: "Yesterday",
          online: true,
        },
        {
          id: 4,
          name: "David Kim",
          avatar: "👨🏻",
          lastMessage: "Meeting at 3pm",
          time: "Yesterday",
          online: false,
        },
      ];

      let currentChatId = null;
      let messages = {}; // Store messages per contact

      // Initialize messages for each contact
      contacts.forEach((contact) => {
        messages[contact.id] = [
          { type: "received", text: "Hi there! How are you?", time: "09:00" },
        ];
      });

      function showContacts() {
        document.getElementById("contacts-screen").classList.remove("hidden");
      }

      function hideContacts() {
        document.getElementById("contacts-screen").classList.add("hidden");
      }

      function openChat(contactId) {
        currentChatId = contactId;
        const contact = contacts.find((c) => c.id === contactId);

        document.getElementById("chat-name").textContent = contact.name;
        document.getElementById("chat-avatar").textContent = contact.avatar;
        document.getElementById("chat-status").textContent = contact.online
          ? "online"
          : "last seen recently";

        hideContacts();
        renderMessages();
      }

      function renderMessages() {
        const chatArea = document.getElementById("chat-area");
        chatArea.innerHTML = "";

        if (!currentChatId || !messages[currentChatId]) return;

        messages[currentChatId].forEach((msg) => {
          const div = document.createElement("div");
          div.className = `message-bubble flex flex-col ${msg.type === "sent" ? "sent" : "received"}`;
          div.innerHTML = `
                    <span>${msg.text}</span>
                    <span class="text-[10px] mt-1 opacity-70">${msg.time}</span>
                `;
          chatArea.appendChild(div);
        });

        chatArea.scrollTop = chatArea.scrollHeight;
      }

      function sendMessage() {
        const input = document.getElementById("message-input");
        const text = input.value.trim();

        if (!text || !currentChatId) return;

        if (!messages[currentChatId]) messages[currentChatId] = [];

        const now = new Date();
        const time =
          now.getHours().toString().padStart(2, "0") +
          ":" +
          now.getMinutes().toString().padStart(2, "0");

        messages[currentChatId].push({
          type: "sent",
          text: text,
          time: time,
        });

        input.value = "";
        renderMessages();

        // Simulate reply after 1 second
        setTimeout(() => {
          if (currentChatId) {
            const replies = [
              "Got it!",
              "Thanks!",
              "Haha true 😂",
              "See you soon!",
              "Okay, noted.",
            ];
            const randomReply =
              replies[Math.floor(Math.random() * replies.length)];

            const replyTime = new Date();
            replyTime.setMinutes(replyTime.getMinutes() + 1);

            messages[currentChatId].push({
              type: "received",
              text: randomReply,
              time:
                replyTime.getHours().toString().padStart(2, "0") +
                ":" +
                replyTime.getMinutes().toString().padStart(2, "0"),
            });

            renderMessages();
          }
        }, 1200);
      }

      function renderContacts() {
        const container = document.getElementById("contacts-list");
        container.innerHTML = "";

        contacts.forEach((contact) => {
          const div = document.createElement("div");
          div.className = `flex items-center gap-4 p-4 hover:bg-gray-100 cursor-pointer border-b`;
          div.innerHTML = `
                    <div class="w-12 h-12 bg-gray-200 rounded-full flex items-center justify-center text-3xl">
                        ${contact.avatar}
                    </div>
                    <div class="flex-1 min-w-0">
                        <div class="flex justify-between">
                            <div class="font-medium truncate">${contact.name}</div>
                            <div class="text-xs text-gray-500">${contact.time}</div>
                        </div>
                        <div class="text-sm text-gray-600 truncate">${contact.lastMessage}</div>
                    </div>
                `;
          div.onclick = () => openChat(contact.id);
          container.appendChild(div);
        });
      }

      // Initialize the app
      function initializeChatApp() {
        renderContacts();

        // Open first chat by default
        setTimeout(() => {
          openChat(1);
        }, 800);

        console.log(
          "%c💬 Chatly - Simple WhatsApp-style chat ready!",
          "color:#25D366; font-weight:bold;",
        );
      }

      window.onload = initializeChatApp;
    </script>
  </body>
</html>
