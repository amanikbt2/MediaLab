### Core (required)
MONGO_URI=mongodb://localhost:27017/medialab
SESSION_SECRET=change-me
APP_BASE_URL=https://medialab.keysire.com
GOOGLE_CALLBACK_URL=https://medialab.keysire.com/auth/google/callback

### VirtualDB (server-side, required for virtual-medialabdb mode)
# Put your `.TempMediaLab` URI here (do not commit `.env`)
VIRTUALDB_MONGO_URI=mongodb+srv://USER:PASS@HOST.mongodb.net/?retryWrites=true&w=majority
